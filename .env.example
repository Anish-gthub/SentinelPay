# CORE SERVER CONFIGURATION
PORT=3000

# DATABASE & CACHE CONNECTIONS
# Replace with your actual PostgreSQL connection string
DATABASE_URL=postgresql://user:password@your-database-host:5432/dbname?sslmode=require

# Local Redis connection (Default)
REDIS_URL=redis://127.0.0.1:6379

# SECURITY & AUTHENTICATION
API_SECRET_KEY=your_secret_api_key_here

# TEST DATA 
# (these will be automatically generated by running 'node seed.js')
TEST_SENDER_WALLET_ID=
TEST_RECEIVER_WALLET_ID=